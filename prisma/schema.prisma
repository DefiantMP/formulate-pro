generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Ingredient template — matches the IngredientLine[] shape in lib/calc-engine/types.ts
model Formulation {
  id        String   @id @default(cuid())
  name      String   @unique
  ingredients Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs         Run[]
  batchHistory BatchHistory[]
}

// A saved calculation: the inputs that produced it, the computed output, and
// which formulation template was in effect.
model Run {
  id            String   @id @default(cuid())
  label         String
  mode          String // 'fresh' | 'regrind'
  formulationId String
  formulation   Formulation @relation(fields: [formulationId], references: [id])
  inputs        Json
  result        Json
  // Audit trail for a Tier 2 AI-verification discrepancy the operator
  // reviewed and acknowledged before saving: { acknowledgedAt, field,
  // reportedValue, computedValue, delta, unit }. Null when the run had no
  // discrepancy needing review.
  verificationAcknowledgment Json?
  createdAt     DateTime @default(now())
}

// A saved regrind lot recipe: potency + excipient makeup, reusable across
// runs. Deliberately excludes weight — that's a per-batch physical
// measurement, not a property of the recurring lot type (e.g. "77 starts").
model RegrindLotPreset {
  id                  String   @id @default(cuid())
  name                String   @unique
  potency             Json // PotencyInput shape from lib/calc-engine/types.ts
  disintegrantPercent Float?
  lubricantPercent    Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Historical manufacturing batches, importable via CSV.
model BatchHistory {
  id                      String   @id @default(cuid())
  date                    DateTime
  formulationId           String?
  formulation             Formulation? @relation(fields: [formulationId], references: [id])
  tabletCount             Int
  targetWeightG           Float
  targetActiveMgPerTablet Float
  notes                   String?
  createdAt               DateTime @default(now())
}
